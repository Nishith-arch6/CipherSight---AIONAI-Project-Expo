import cv2
from ultralytics import YOLO

# 1. Load the model
model = YOLO('yolov8n.pt') 

# 2. Open the webcam
cap = cv2.VideoCapture(0)

while cap.isOpened():
    ret, frame = cap.read()
    if not ret: break

    # 3. Perform detection
    # 'classes=...' allows you to filter specifically for vehicles if needed
    results = model(frame, stream=True)

    for r in results:
        boxes = r.boxes
        for box in boxes:
            cls = int(box.cls[0])
            label = model.names[cls]
            
            # Check for 'ambulance' (if using a custom trained model) 
            # Or use 'truck'/'car' for initial testing
            if label == 'ambulance': 
                confidence = float(box.conf[0])
                if confidence > 0.6:
                    # DRAWING: Add visual feedback
                    x1, y1, x2, y2 = map(int, box.xyxy[0])
                    cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 0), 2)
                    cv2.putText(frame, "AMBULANCE DETECTED", (x1, y1 - 10), 
                                cv2.FONT_HERSHEY_SIMPLEX, 0.9, (0, 255, 0), 2)
                    
                    # ALERT: Trigger API signal here
                    # notify_routing_system(status="ambulance_detected")

    cv2.imshow('CipherSight AI Feed', frame)
    if cv2.waitKey(1) == ord('q'): break

cap.release()
cv2.destroyAllWindows()

model.train(data='your_data.yaml', epochs=50, imgsz=640)
